# Base Sepolia Testnet Configuration
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Optional: Flashblocks RPC for preconfirmations
BASE_SEPOLIA_FLASHBLOCKS_RPC_URL=https://sepolia-preconf.base.org

# Block Explorer API Key (optional)
BASESCAN_API_KEY=your_basescan_api_key_here

# Reown (WalletConnect) Project ID
REOWN_PROJECT_ID=your_reown_project_id_here

# Dune Analytics API Key (https://dune.com/settings/api)
# Enables: curated queries, raw SQL (run-sql), table discovery,
# blockchain listing, query management, and AI chat tools.
# CLI docs: https://docs.dune.com/api-reference/agents/cli-and-skills
DUNE_API_KEY=your_dune_api_key_here
